{
  "name": "version-watcher",
  "version": "1.0.7",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./index.d.ts"
    },
    "./plugin": "./dist/plugin/index.cjs",
    "./plugin/vite": "./dist/plugin/vite.mjs",
    "./theme-chalk": "./dist/theme-chalk.css",
    "./assets/*": "./dist/static/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "index.d.ts"
  ],
  "scripts": {
    "build": "rimraf dist && rollup -c",
    "build:watch": "rimraf dist && rollup -cw",
    "test": "node tests/run-tests.cjs",
    "smoke:pack": "node ./scripts/pack-and-smoke.cjs",
    "verify:node": "node ./scripts/verify-node-compat.cjs",
    "example:dev": "npm --prefix examples/vite-demo run dev",
    "example:build": "npm --prefix examples/vite-demo run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^2.6.0 || ^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@babel/preset-env": "^7.26.7",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^23.0.7",
    "@rollup/plugin-eslint": "^9.0.5",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "autoprefixer": "^10.4.20",
    "core-js": "^2.6.12",
    "fs-extra": "^11.3.0",
    "postcss": "^8.5.1",
    "postcss-import": "^16.1.0",
    "postcss-loader": "^8.1.1",
    "regenerator-runtime": "^0.14.1",
    "rollup": "^2.79.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-scss": "^4.0.1",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-web-worker-loader": "^1.7.0",
    "sass": "^1.84.0"
  },
  "keywords": [
    "version-watcher",
    "vue-plugin"
  ],
  "author": "Miraquai",
  "license": "MIT"
}
